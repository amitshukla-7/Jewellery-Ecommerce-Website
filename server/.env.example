# Copy this file to .env and fill in your values

# MongoDB Connection URI
# Local:   mongodb://localhost:27017/aura-jewels
# Atlas:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/aura-jewels
MONGO_URI=mongodb://localhost:27017/aura-jewels

# JWT Secret
JWT_SECRET=aura_jewels_secret_key_2024

# Server Port
PORT=5000

# Node Environment: development | production
NODE_ENV=development

# Brand Info
CONTACT_EMAIL=contact@aurajewels.com
SUPPORT_EMAIL=support@aurajewels.com
PHONE=+9198765XXXXX
